{
  "name": "gdgica.com",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "npx eslint .",
    "format": "prettier -w --cache .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:functions": "cd functions && npm test",
    "test:rules": "firebase --project demo-gdgica emulators:exec --only firestore,auth \"vitest run --config tests/rules/vitest.config.ts\"",
    "test:all": "pnpm test && pnpm test:functions && pnpm test:rules"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.7",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.4.1",
    "@fancyapps/ui": "^6.0.28",
    "@fontsource-variable/geist": "^5.2.9",
    "@lucide/astro": "^1.18.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "astro": "^5.10.1",
    "clsx": "^2.1.1",
    "firebase": "^12.13.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@vitest/ui": "^4.1.5",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.3.1",
    "firebase-tools": "^15.20.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.35.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.15.0"
  }
}
