---
import Layout from "@/layouts/Layout.astro";
import SponsorCard from "@/components/SponsorCard.astro";
import { Users, Target, Zap, Heart, BriefcaseBusiness } from "@lucide/astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import Button from "@/components/Button.astro";
import HeroPage from "@/components/HeroPage.astro";

import { getCollection } from "astro:content";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import StatsBar from "@/components/StatsBar.astro";

const sponsorsCollection = await getCollection("sponsors");
const sponsors = sponsorsCollection.map((entry) => entry.data);
const stats = await fetchStats();
const links = await fetchLinks();

const metadata = {
  title: "Patrocinadores - Google Developer Group Ica",
  description:
    "Descubre las empresas que apoyan al GDG ICA y cómo tu organización puede patrocinar eventos tech en Ica, Perú. Conecta con más de 5000 desarrolladores de la región.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/patrocinadores/",
};
---

<Layout {...metadata}>
  <HeroPage>
    <p
      class="mb-6 inline-flex h-24 w-24 items-center justify-center rounded-2xl bg-gradient-to-r from-blue-600 via-red-500 to-green-600"
    >
      <BriefcaseBusiness stroke-width={1.5} size={64} color="#FFFFFF" />
    </p>
    <h1 class="mb-6 text-4xl font-bold md:text-5xl">
      <span class="text-google-blue">Nuestros </span>
      <span class="text-google-red">Patrocinadores</span>
    </h1>
    <p class="text-secondary mx-auto mb-12 max-w-3xl text-xl">
      Agradecemos profundamente a las empresas y organizaciones que hacen
      posible nuestra misión de democratizar el acceso al conocimiento
      tecnológico. Su apoyo transforma vidas y construye el futuro digital.
    </p>

    <StatsBar
      stats={[
        {
          value: `${stats.totalSponsors}+`,
          label: "Patrocinadores Activos",
          color: "blue",
        },
        {
          value: stats.annualSupport,
          label: "Apoyo Anual Total",
          color: "red",
        },
        {
          value: `${stats.sponsoredEvents}+`,
          label: "Eventos Patrocinados",
          color: "yellow",
        },
        {
          value: `${stats.developersReached}+`,
          label: "Desarrolladores Alcanzados",
          color: "green",
        },
      ]}
    />
  </HeroPage>

  <section class="py-20">
    <div class="container">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold">Patrocinadores Principales</h2>
        <p class="text-secondary text-xl">
          Nuestros socios estratégicos que impulsan la innovación y el
          crecimiento de la comunidad
        </p>
      </div>
      <div
        class="mx-auto mt-12 grid max-w-4xl grid-cols-1 gap-8 md:grid-cols-2"
      >
        {
          sponsors
            .filter((sponsor) => sponsor.featured)
            .map((sponsor) => <SponsorCard {...sponsor} />)
        }
      </div>
    </div>
  </section>

  <section class="bg-section py-20">
    <div class="container">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="mb-4 text-3xl font-bold">Todos Nuestros Patrocinadores</h2>
        <p class="text-secondary text-xl">
          Cada empresa que nos apoya es fundamental para nuestro éxito
        </p>
      </div>
      <div
        class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
      >
        {
          sponsors
            .filter((sponsor) => !sponsor.featured)
            .map((sponsor) => <SponsorCard {...sponsor} />)
        }
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container">
      <div class="mx-auto mb-14 max-w-[523px] text-center">
        <h2 class="mb-6 text-4xl font-bold">¿Por Qué Patrocinar GDG?</h2>
        <p class="text-secondary text-xl">
          Los beneficios tangibles de asociarse con la comunidad de
          desarrolladores más activa de la región
        </p>
      </div>
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <!-- const benefitIconMap = { Users, Target, Zap, Heart }; -->
        <article
          class="flex flex-col items-center justify-center gap-3 rounded-lg border border-gray-200 p-6 text-center"
        >
          <Users stroke-width={1.5} class="h-8 w-8" color="#2563EB" />
          <h3 class="text-primary text-2xl font-semibold">Acceso a talento</h3>
          <p class="text-secondary text-sm">
            Conecta directamente con desarrolladores talentosos y apasionados de
            la región.
          </p>
        </article>
        <article
          class="flex flex-col items-center justify-center gap-3 rounded-lg border border-gray-200 p-6 text-center"
        >
          <Target stroke-width={1.5} class="h-8 w-8" color="#DC2626" />
          <h3 class="text-primary text-2xl font-semibold">Brand Awareness</h3>
          <p class="text-secondary text-sm">
            Aumenta la visibilidad de tu marca en la comunidad tech más activa
            de la región.
          </p>
        </article>
        <article
          class="flex flex-col items-center justify-center gap-3 rounded-lg border border-gray-200 p-6 text-center"
        >
          <Zap stroke-width={1.5} class="h-8 w-8" color="#F59E0B" />
          <h3 class="text-primary text-2xl font-semibold">
            Thought Leadership
          </h3>
          <p class="text-secondary text-sm">
            Posiciona tu empresa como líder tecnológico compartiendo
            conocimiento y experiencia.
          </p>
        </article>
        <article
          class="flex flex-col items-center justify-center gap-3 rounded-lg border border-gray-200 p-6 text-center"
        >
          <Heart stroke-width={1.5} class="h-8 w-8" color="#16A34A" />
          <h3 class="text-primary text-2xl font-semibold">Community Impact</h3>
          <p class="text-secondary text-sm">
            Contribuye al crecimiento del ecosistema tecnológico y genera
            impacto social positivo.
          </p>
        </article>
      </div>
    </div>
  </section>
  <CallToActionSection>
    <h2 class="mb-6 text-3xl font-bold text-white md:text-4xl">
      ¿Quieres Ser Nuestro Próximo Patrocinador?
    </h2>
    <p class="mb-8 text-xl text-white">
      Únete a las empresas líderes que apoyan el crecimiento del ecosistema
      tecnológico. Juntos podemos formar a los desarrolladores del futuro y
      crear un impacto duradero en la industria.
    </p>
    <Button variant="white" href={links.forms.sponsor} target="_blank">
      <BriefcaseBusiness />
      Quiero ser patrocinador
    </Button>
  </CallToActionSection>
</Layout>
