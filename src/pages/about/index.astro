---
import Layout from "@/layouts/Layout.astro";
import HeroPage from "@/components/HeroPage.astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import PersonCard from "@/components/PersonCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Button from "@/components/Button.astro";
import { MapPin, Users, Calendar, User } from "@lucide/astro";
// data
import { getCollection } from "astro:content";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import { buildAboutSchema } from "@/utils/schema";

const organizersCollection = await getCollection("organizers");
const organizers = organizersCollection.map((entry) => entry.data);
const galleryCollection = await getCollection("gallery");
const gallery = galleryCollection.map((entry) => entry.data);
const stats = await fetchStats();
const links = await fetchLinks();

import { Gallery } from "@/components/react/Gallery";

const facts = [
  { Icon: MapPin, label: "Ica, Perú" },
  { Icon: Users, label: `${stats.totalMembers}+ miembros` },
  { Icon: Calendar, label: `${stats.yearsActive}+ años activos` },
];

const metadata = {
  title: "Nosotros - Google Developer Group Ica",
  description:
    "Conoce la historia, misión y equipo del Google Developer Group Ica. Más de 10 años conectando desarrolladores en Ica, Perú.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/about/",
  schema: buildAboutSchema(links.social),
};
---

<Layout {...metadata}>
  <HeroPage
    eyebrow="Nosotros"
    title="Somos GDG Ica"
    description="Una comunidad vibrante de desarrolladores unidos por la pasión de crear, aprender y compartir conocimiento sobre las tecnologías de Google. Somos el punto de encuentro para desarrolladores de todos los niveles."
  >
    <ul class="mt-10 flex flex-wrap gap-3">
      {
        facts.map(({ Icon, label }) => (
          <li class="border-line bg-surface text-fg flex items-center gap-2 rounded-full border px-4 py-2 text-sm font-medium">
            <Icon
              size={16}
              stroke-width={1.75}
              class="text-fg-subtle"
              aria-hidden
            />
            {label}
          </li>
        ))
      }
    </ul>
  </HeroPage>

  <section class="border-line bg-surface border-t">
    <div class="section container">
      <SectionHeader
        eyebrow="Organizadores"
        title="Quiénes hacen que esto pase"
        description="Conoce al equipo organizador detrás de cada evento."
      />
      <div
        class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
      >
        {organizers.map((organizer) => <PersonCard person={organizer} />)}
      </div>
    </div>
  </section>

  <section class="section container">
    <SectionHeader
      eyebrow="Galería"
      title="Momentos de la comunidad"
      description="Revive los mejores momentos de nuestros eventos."
    />
    <div class="mt-14">
      <Gallery client:visible gallery={gallery} />
    </div>
  </section>

  <CallToActionSection
    title="¿Quieres ser parte de nuestra historia?"
    description="Únete a la comunidad y ayúdanos a escribir el siguiente capítulo del GDG Ica."
  >
    <Button
      href={links.forms.joinCommunity}
      target="_blank"
      variant="inverse"
      size="lg"
    >
      <User size={18} stroke-width={1.75} aria-hidden />
      Únete a la comunidad
    </Button>
  </CallToActionSection>
</Layout>
