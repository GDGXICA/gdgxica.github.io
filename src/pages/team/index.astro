---
import Button from "@/components/Button.astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import HeroPage from "@/components/HeroPage.astro";
import Layout from "@/layouts/Layout.astro";
import PersonCard from "@/components/PersonCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { Users } from "@lucide/astro";
import { getCollection } from "astro:content";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import StatsBar from "@/components/StatsBar.astro";
import { buildTeamSchema } from "@/utils/schema";

const membersCollection = await getCollection("members");
const members = membersCollection.map((entry) => entry.data);
const stats = await fetchStats();
const links = await fetchLinks();

const metadata = {
  title: "Equipo - Google Developer Group Ica",
  description:
    "Conoce al equipo de organizadores del Google Developer Group Ica. 7 organizadores activos con más de 10 años de experiencia construyendo comunidad tech en Ica, Perú.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/team/",
  schema: buildTeamSchema(members, links.social),
};
---

<Layout {...metadata}>
  <HeroPage
    eyebrow="Equipo"
    title="Las personas detrás de la comunidad"
    description="Voluntarios apasionados que dedican su tiempo y experiencia para crear un espacio donde todos puedan aprender y crecer."
  >
    <StatsBar
      class="border-line mt-16 border-t pt-12"
      stats={[
        {
          value: `${stats.totalOrganizers}`,
          label: "Organizadores activos",
          color: "blue",
        },
        {
          value: `${stats.yearsActive}+`,
          label: "Años de experiencia",
          color: "red",
        },
        {
          value: `${stats.totalEvents}+`,
          label: "Eventos organizados",
          color: "yellow",
        },
        {
          value: `${stats.developersMentored}+`,
          label: "Desarrolladores mentoreados",
          color: "green",
        },
      ]}
    />
  </HeroPage>

  <section class="section container">
    <SectionHeader
      eyebrow="Miembros"
      title="Todo el equipo"
      description="Conoce a todas las personas que mueven el GDG Ica."
    />

    {
      members.length > 0 ? (
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {members.map((member) => (
            <PersonCard person={member} variant="detailed" />
          ))}
        </div>
      ) : (
        <div class="card mt-14 p-10 text-center">
          <p class="text-fg-muted">
            Estamos actualizando la lista del equipo. Vuelve pronto.
          </p>
        </div>
      )
    }
  </section>

  <CallToActionSection
    title="¿Quieres unirte a nuestro equipo?"
    description="Buscamos personas apasionadas que quieran contribuir al crecimiento de la comunidad. Si tienes ganas de hacer la diferencia, nos encantaría conocerte."
  >
    <Button
      href={links.forms.joinTeam}
      target="_blank"
      variant="inverse"
      size="lg"
    >
      <Users size={18} stroke-width={1.75} aria-hidden />
      Aplicar al equipo
    </Button>
  </CallToActionSection>
</Layout>
