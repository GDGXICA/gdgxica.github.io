---
import Layout from "@/layouts/Layout.astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import Button from "@/components/Button.astro";
import Marquee from "@/components/Marquee.astro";
import FeatureCard from "@/components/FeatureCard.astro";
import EventCard from "@/components/EventCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import StatsBar from "@/components/StatsBar.astro";
import DuneDivider from "@/components/DuneDivider.astro";
import { getCollection } from "astro:content";
import { parseSpanishDate } from "@/utils/parseSpanishDate";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import {
  Users,
  ArrowRight,
  UsersRound,
  Lightbulb,
  HeartHandshake,
  Sprout,
  CalendarPlus,
} from "@lucide/astro";

const allEvents = await getCollection("events");
const upcomingEvents = allEvents
  .filter((event) => event.data.status.type === "upcoming")
  .sort((a, b) => {
    const dateA = parseSpanishDate(a.data.date);
    const dateB = parseSpanishDate(b.data.date);
    return dateA.getTime() - dateB.getTime();
  });

const stats = await fetchStats();
const links = await fetchLinks();

// Real venues, straight from the event data. The site named "Ica" exactly once
// before this; the places the community actually meets are the most authentic
// identity available and need no illustration.
const venueCounts = new Map<string, number>();
for (const event of allEvents) {
  if (event.data.isVirtual) continue;
  const name = event.data.location?.name?.trim();
  if (name) venueCounts.set(name, (venueCounts.get(name) ?? 0) + 1);
}
const venues = [...venueCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6);

const benefits = [
  {
    Icon: UsersRound,
    title: "Conectar",
    tone: "text-brand-blue-text",
    rule: "bg-brand-blue",
    body: "Hacer networking con profesionales, estudiantes y otros apasionados por la tecnología de Ica y alrededores.",
  },
  {
    Icon: Lightbulb,
    title: "Aprender",
    tone: "text-brand-red-text",
    rule: "bg-brand-red",
    body: "Participar en charlas técnicas, workshops y study jams sobre Android, Google Cloud, Web, AI/ML, Firebase, Flutter y mucho más.",
  },
  {
    Icon: HeartHandshake,
    title: "Compartir",
    tone: "text-brand-yellow-text",
    rule: "bg-brand-yellow",
    body: "Presentar tus propios proyectos, compartir tus conocimientos y convertirte en un referente para otros.",
  },
  {
    Icon: Sprout,
    title: "Crecer",
    tone: "text-brand-green-text",
    rule: "bg-brand-green",
    body: "Desarrollar tus habilidades técnicas y blandas, y dar un impulso a tu trayectoria profesional con el apoyo de una red activa.",
  },
];

const metadata = {
  title: "GDG ICA - Google Developer Group Ica",
  description:
    "Comunidad oficial de Google Developer Group en Ica, Perú. Conectamos desarrolladores con eventos, workshops y charlas sobre Android, Cloud, IA, Flutter y Firebase.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/",
  schema: [
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      name: "Google Developer Group ICA",
      alternateName: "GDG ICA",
      url: "https://gdgica.com",
      logo: "https://gdgica.com/gdg-logo.png",
      description:
        "Comunidad oficial de Google Developer Group en Ica, Perú. Más de 1000 miembros activos, 50+ eventos y 10 años conectando desarrolladores.",
      sameAs: ["https://gdg.community.dev/gdg-ica/"],
    },
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      name: "GDG ICA",
      url: "https://gdgica.com",
    },
  ],
};
---

<Layout {...metadata}>
  {
    /* Hero — text comes first in source order so mobile leads with the
      headline instead of a wall of photos. */
  }
  <section
    class="relative isolate flex min-h-[34rem] items-end overflow-hidden lg:min-h-[42rem]"
  >
    <img
      src="/events/devfest-2025.webp"
      alt=""
      width={1920}
      height={1080}
      fetchpriority="high"
      decoding="async"
      class="absolute inset-0 -z-20 h-full w-full object-cover object-center"
    />

    {
      /*
      ONE diagonal scrim, not two stacked ones. Two scrims multiply their
      transmission — 0.92 over 0.82 left only ~2% of the photo showing, which
      defeated the point of using a photo at all. This darkens the bottom-left
      where the copy sits and clears out toward the top-right so the crowd
      stays visible.
    */
    }
    <div
      class="absolute inset-0 -z-10"
      style="background: linear-gradient(to top right, color-mix(in srgb, var(--ink) 88%, transparent) 0%, color-mix(in srgb, var(--ink) 62%, transparent) 30%, color-mix(in srgb, var(--ink) 22%, transparent) 62%, transparent 85%);"
      aria-hidden="true"
    >
    </div>

    {
      /* Localised pool behind the copy only. Measured: the diagonal scrim alone
        left the lead paragraph at 3.06:1, under the 4.5:1 floor for body text,
        while the headline was fine. Confining the extra darkening here keeps
        the photo readable everywhere else. */
    }
    <div
      class="absolute inset-0 -z-10"
      style="background: radial-gradient(120% 95% at 0% 100%, color-mix(in srgb, var(--ink) 78%, transparent) 0%, color-mix(in srgb, var(--ink) 45%, transparent) 42%, transparent 72%);"
      aria-hidden="true"
    >
    </div>

    <div class="section relative container">
      <div class="animate-fade-up max-w-3xl">
        <p
          class="text-overline text-fg-on-ink mb-6 flex items-center gap-3 uppercase"
        >
          <span class="brand-rule h-1 w-10 rounded-full" aria-hidden="true"
          ></span>
          Comunidad tech · Ica, Perú
        </p>

        <h1 class="text-display text-fg-on-ink text-balance">
          Conecta, aprende y construye.
        </h1>

        <p class="text-lead text-fg-on-ink mt-7 max-w-xl text-pretty">
          Somos una comunidad de jóvenes apasionados por la tecnología en Ica.
          Únete a nuestros eventos, comparte conocimiento y lleva tus
          habilidades al siguiente nivel.
        </p>

        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <Button
            href={links.community}
            target="_blank"
            variant="inverse"
            size="lg"
          >
            Únete a GDG hoy
            <ArrowRight size={18} stroke-width={2} aria-hidden />
          </Button>
          <Button href="/events" variant="inverse-outline" size="lg">
            Ver eventos
          </Button>
        </div>
      </div>
    </div>
  </section>

  {/* Dune crest instead of a hard rule into the stats band. */}
  <DuneDivider class="text-surface" />

  {/* Stats */}
  <section class="border-line bg-surface grain border-b">
    <div class="section-tight container">
      <StatsBar
        stats={[
          {
            value: `${stats.totalMembers}+`,
            label: "Miembros activos",
            color: "blue",
          },
          { value: `${stats.totalEvents}+`, label: "Eventos", color: "red" },
          {
            value: `${stats.totalSpeakers}+`,
            label: "Expertos speakers",
            color: "yellow",
          },
          {
            value: `${stats.yearsActive}+`,
            label: "Años activos",
            color: "green",
          },
        ]}
      />
    </div>
  </section>

  {/* Benefits */}
  <section class="section container">
    <SectionHeader
      eyebrow="Por qué unirte"
      title="Una comunidad que te impulsa"
      description="Descubre los beneficios de ser parte de nuestra comunidad de desarrolladores."
    />

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        benefits.map(({ Icon, title, body, tone, rule }) => (
          <FeatureCard interactive class="flex flex-col">
            <span
              class={`mb-5 block h-1 w-9 rounded-full ${rule}`}
              aria-hidden="true"
            />
            <Icon size={28} stroke-width={1.75} class={tone} aria-hidden />
            <h3 class="text-h4 text-fg mt-4">{title}</h3>
            <p class="text-fg-muted mt-2 text-sm">{body}</p>
          </FeatureCard>
        ))
      }
    </div>
  </section>

  {/* Upcoming events */}
  <section class="border-line bg-surface border-t">
    <div class="section container">
      <SectionHeader
        eyebrow="Agenda"
        title="Próximos eventos"
        description="No te pierdas lo que viene en la comunidad."
      />

      {
        upcomingEvents.length > 0 ? (
          <div
            class:list={[
              "mt-14 grid gap-6",
              upcomingEvents.length === 1
                ? "max-w-2xl"
                : upcomingEvents.length === 2
                  ? "sm:grid-cols-2"
                  : "sm:grid-cols-2 lg:grid-cols-3",
            ]}
          >
            {upcomingEvents.map((event) => (
              <EventCard slug={event.id} {...event.data} />
            ))}
          </div>
        ) : (
          <div class="card mt-14 flex flex-col items-center gap-6 p-10 text-center md:flex-row md:justify-between md:text-left">
            <div class="flex items-center gap-5">
              <span
                class="bg-brand-blue-soft text-brand-blue-text hidden h-14 w-14 shrink-0 items-center justify-center rounded-full sm:inline-flex"
                aria-hidden="true"
              >
                <CalendarPlus size={24} stroke-width={1.75} />
              </span>
              <div>
                <h3 class="text-h3 text-fg">Nuevos eventos muy pronto</h3>
                <p class="text-fg-muted mt-2 max-w-md text-pretty">
                  Estamos preparando la siguiente tanda de workshops y charlas.
                  Únete a la comunidad para enterarte primero.
                </p>
              </div>
            </div>
            <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
              <Button href={links.community} target="_blank">
                <Users size={18} stroke-width={1.75} aria-hidden />
                Únete
              </Button>
              <Button href="/events" variant="secondary">
                Ver eventos pasados
              </Button>
            </div>
          </div>
        )
      }
    </div>
  </section>

  {
    /* Real places in Ica. The site named the city exactly once before this;
      the venues the community actually meets in are the most authentic
      identity available, and need no illustration. */
  }
  {
    venues.length > 0 && (
      <section class="section container">
        <SectionHeader
          eyebrow="Dónde nos reunimos"
          title="Sedes de la comunidad en Ica"
          description="Nos juntamos en universidades e institutos de la región. Estas son las que más nos han acogido."
        />
        <ul class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {venues.map(([name, count], i) => (
            <li class="card card-interactive flex items-start gap-4 p-5">
              <span
                class="text-brand-blue-text bg-brand-blue-soft flex h-11 w-11 shrink-0 items-center justify-center rounded-md text-sm font-bold tabular-nums"
                aria-hidden="true"
              >
                {String(i + 1).padStart(2, "0")}
              </span>
              <div class="min-w-0">
                <h3 class="text-h4 text-fg text-balance">{name}</h3>
                <p class="text-fg-subtle mt-1 text-sm">
                  {count} {count === 1 ? "evento" : "eventos"} · Ica, Perú
                </p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    /* Community photo band — the marquee moved out of the hero, where the
      full-bleed photo now carries that job, into a section of its own. */
  }
  <section class="border-line bg-bg overflow-hidden border-t">
    <div class="section-tight container">
      <SectionHeader
        eyebrow="La comunidad"
        title="Así se ve un evento del GDG Ica"
        description="Fotos de nuestros meetups, workshops y DevFests."
      />
    </div>
    <div class="mt-4">
      <Marquee />
    </div>
  </section>

  <CallToActionSection
    title="¿Listo para unirte a nuestra comunidad?"
    description="Conéctate con desarrolladores, aprende nuevas tecnologías y construyan proyectos increíbles juntos."
  >
    <Button href={links.community} target="_blank" variant="inverse" size="lg">
      <Users size={18} stroke-width={1.75} aria-hidden />
      Únete a GDG hoy
    </Button>
    <Button href="/events" variant="inverse-outline" size="lg">
      Ver eventos
    </Button>
  </CallToActionSection>
</Layout>
