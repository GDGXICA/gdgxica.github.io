---
import Button from "@/components/Button.astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import EventCard from "@/components/EventCard.astro";
import HeroPage from "@/components/HeroPage.astro";
import Layout from "@/layouts/Layout.astro";
import { Calendar } from "@lucide/astro";
import { getCollection } from "astro:content";
import { parseSpanishDate } from "@/utils/parseSpanishDate";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import StatsBar from "@/components/StatsBar.astro";
import { EventFilters } from "@/components/react/EventFilters";

const allEventsRaw = await getCollection("events");

const upcomingEvents = allEventsRaw
  .filter((event) => event.data.status.type === "upcoming")
  .sort((a, b) => {
    const dateA = parseSpanishDate(a.data.date);
    const dateB = parseSpanishDate(b.data.date);
    return dateA.getTime() - dateB.getTime();
  });

const pastEvents = allEventsRaw
  .filter((event) => event.data.status.type !== "upcoming")
  .sort((a, b) => {
    const dateA = parseSpanishDate(a.data.date);
    const dateB = parseSpanishDate(b.data.date);
    return dateB.getTime() - dateA.getTime();
  });

const allEvents = [...upcomingEvents, ...pastEvents];

const highLightEvent = upcomingEvents.find((event) => event.data.isHighlight);

const stats = await fetchStats();
const links = await fetchLinks();

const metadata = {
  title: "Eventos - Google Developer Group Ica",
  description:
    "Explora más de 50 eventos de Android, Cloud, IA, Flutter y Firebase organizados por GDG ICA en Ica, Perú. Calendario de próximos eventos y archivo completo.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/events/",
};
---

<Layout {...metadata}>
  <HeroPage>
    <div class="mx-auto max-w-[768px] text-center">
      <p
        class="mb-6 inline-flex h-24 w-24 items-center justify-center rounded-2xl bg-gradient-to-r from-blue-600 via-red-500 to-green-600"
      >
        <Calendar stroke-width={1.5} size={64} color="#FFFFFF" />
      </p>
      <h1 class="mb-6 text-4xl font-bold md:text-5xl">
        <span class="text-google-blue">Nuestros</span>
        <span class="text-google-red">Eventos</span>
      </h1>
      <p class="text-secondary mb-8 text-xl">
        Una comunidad vibrante de desarrolladores unidos por la pasión de crear,
        aprender y compartir conocimiento sobre las tecnologías de Google. Desde
        2019, hemos sido el punto de encuentro para desarrolladores de todos los
        niveles.
      </p>

      <StatsBar
        stats={[
          {
            value: `${stats.totalMembers}+`,
            label: "Miembros activos",
            color: "blue",
          },
          { value: `${stats.totalEvents}+`, label: "Eventos", color: "red" },
          {
            value: `${stats.totalSpeakers}+`,
            label: "Expertos speakers",
            color: "yellow",
          },
          {
            value: `${stats.yearsActive}+`,
            label: "Años activos",
            color: "green",
          },
        ]}
      />
      {
        highLightEvent && (
          <>
            <p class="mt-[65px] mb-8 text-2xl font-bold">
              Próximo Evento Destacado
            </p>
          </>
        )
      }
    </div>
    {
      highLightEvent && (
        <div class="mx-auto max-w-[1152px]">
          <EventCard
            isHorizontal={true}
            slug={highLightEvent?.id}
            {...highLightEvent?.data}
          />
        </div>
      )
    }
  </HeroPage>
  <section class="py-20">
    <div class="container">
      <h2 class="text-primary mb-6 text-center text-4xl font-bold">
        Todos los Eventos
      </h2>
      <p class="text-secondary text-center text-xl">
        Explora nuestro catálogo completo de eventos pasados y próximos
      </p>
      <EventFilters client:visible />
      <div
        class="grid-col-1 sm:grid-col-2 md:grid-col-2 mt-12 grid gap-8 lg:grid-cols-3"
      >
        {
          allEvents.map((event) => (
            <div
              class="h-full"
              data-event-card
              data-name={event.data.name.toLowerCase()}
              data-category={event.data.category.type}
              data-status={event.data.status.type}
              data-tags={event.data.tags.join(",").toLowerCase()}
            >
              <EventCard slug={event.id} {...event.data} />
            </div>
          ))
        }
      </div>
      <p
        id="events-empty"
        class="text-secondary mt-12 hidden text-center text-xl"
      >
        No hay eventos que coincidan con tu búsqueda.
      </p>
    </div>
  </section>
  <CallToActionSection>
    <h2 class="mb-6 text-3xl font-bold text-white md:text-4xl">
      ¿Tienes una idea para un evento?
    </h2>
    <p class="mb-8 text-xl text-white">
      Ayúdanos a crear eventos increíbles. Propón un tema, sugiere un speaker o
      colabora en la organización de nuestros próximos eventos.
    </p>
    <Button variant="white" href={links.forms.proposeEvent} target="_blank">
      <Calendar />
      Proponer Evento
    </Button>
  </CallToActionSection>
</Layout>
