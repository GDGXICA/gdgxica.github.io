---
import Button from "@/components/Button.astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import EventCard from "@/components/EventCard.astro";
import HeroPage from "@/components/HeroPage.astro";
import Layout from "@/layouts/Layout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { Calendar } from "@lucide/astro";
import { getCollection } from "astro:content";
import { parseSpanishDate } from "@/utils/parseSpanishDate";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import StatsBar from "@/components/StatsBar.astro";
import { EventFilters } from "@/components/react/EventFilters";

const allEventsRaw = await getCollection("events");

const upcomingEvents = allEventsRaw
  .filter((event) => event.data.status.type === "upcoming")
  .sort((a, b) => {
    const dateA = parseSpanishDate(a.data.date);
    const dateB = parseSpanishDate(b.data.date);
    return dateA.getTime() - dateB.getTime();
  });

const pastEvents = allEventsRaw
  .filter((event) => event.data.status.type !== "upcoming")
  .sort((a, b) => {
    const dateA = parseSpanishDate(a.data.date);
    const dateB = parseSpanishDate(b.data.date);
    return dateB.getTime() - dateA.getTime();
  });

const allEvents = [...upcomingEvents, ...pastEvents];

const highLightEvent = upcomingEvents.find((event) => event.data.isHighlight);

const stats = await fetchStats();
const links = await fetchLinks();

const metadata = {
  title: "Eventos - Google Developer Group Ica",
  description:
    "Explora más de 50 eventos de Android, Cloud, IA, Flutter y Firebase organizados por GDG ICA en Ica, Perú. Calendario de próximos eventos y archivo completo.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/events/",
};
---

<Layout {...metadata}>
  <HeroPage
    eyebrow="Eventos"
    title="Workshops, charlas y meetups"
    description="Explora el catálogo completo de eventos de la comunidad: desde study jams y charlas técnicas hasta el DevFest anual."
  >
    <StatsBar
      class="border-line mt-16 border-t pt-12"
      stats={[
        {
          value: `${stats.totalMembers}+`,
          label: "Miembros activos",
          color: "blue",
        },
        { value: `${stats.totalEvents}+`, label: "Eventos", color: "red" },
        {
          value: `${stats.totalSpeakers}+`,
          label: "Expertos speakers",
          color: "yellow",
        },
        {
          value: `${stats.yearsActive}+`,
          label: "Años activos",
          color: "green",
        },
      ]}
    />
  </HeroPage>

  {
    highLightEvent && (
      <section class="border-line bg-surface border-t">
        <div class="section container">
          <SectionHeader eyebrow="Destacado" title="Próximo evento destacado" />
          {/* Full container width — the old markup nested this inside the
              hero's 768px wrapper, squeezing the horizontal card. */}
          <div class="mt-10">
            <EventCard
              isHorizontal={true}
              slug={highLightEvent.id}
              {...highLightEvent.data}
            />
          </div>
        </div>
      </section>
    )
  }

  <section class="section container">
    <SectionHeader
      eyebrow="Catálogo"
      title="Todos los eventos"
      description="Explora nuestro catálogo completo de eventos pasados y próximos."
    />

    <EventFilters client:visible />

    <div
      id="events-grid"
      class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      {
        allEvents.map((event) => (
          <div
            class="h-full"
            data-event-card
            data-name={event.data.name.toLowerCase()}
            data-category={event.data.category.type}
            data-status={event.data.status.type}
            data-tags={event.data.tags.join(",").toLowerCase()}
          >
            <EventCard slug={event.id} {...event.data} />
          </div>
        ))
      }
    </div>

    <p id="events-empty" class="text-fg-muted mt-12 hidden text-center">
      No hay eventos que coincidan con tu búsqueda.
    </p>
  </section>

  <CallToActionSection
    title="¿Tienes una idea para un evento?"
    description="Propón un tema, sugiere un speaker o colabora en la organización de los próximos eventos."
  >
    <Button
      href={links.forms.proposeEvent}
      target="_blank"
      variant="inverse"
      size="lg"
    >
      <Calendar size={18} stroke-width={1.75} aria-hidden />
      Proponer evento
    </Button>
  </CallToActionSection>
</Layout>
