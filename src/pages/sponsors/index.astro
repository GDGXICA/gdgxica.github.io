---
import Layout from "@/layouts/Layout.astro";
import SponsorCard from "@/components/SponsorCard.astro";
import FeatureCard from "@/components/FeatureCard.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import { Users, Target, Zap, Heart, BriefcaseBusiness } from "@lucide/astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import Button from "@/components/Button.astro";
import HeroPage from "@/components/HeroPage.astro";

import { getCollection } from "astro:content";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import StatsBar from "@/components/StatsBar.astro";
import { buildSponsorsSchema } from "@/utils/schema";

const sponsorsCollection = await getCollection("sponsors");
const sponsors = sponsorsCollection.map((entry) => entry.data);
const featuredSponsors = sponsors.filter((sponsor) => sponsor.featured);
const otherSponsors = sponsors.filter((sponsor) => !sponsor.featured);
const stats = await fetchStats();
const links = await fetchLinks();

// Previously four hand-duplicated <article> blocks, which is what the
// leftover `benefitIconMap` comment in this file was reaching for.
const benefits = [
  {
    Icon: Users,
    title: "Acceso a talento",
    tone: "text-brand-blue-text",
    rule: "bg-brand-blue",
    body: "Conecta directamente con desarrolladores talentosos y apasionados de la región.",
  },
  {
    Icon: Target,
    title: "Visibilidad de marca",
    tone: "text-brand-red-text",
    rule: "bg-brand-red",
    body: "Aumenta la visibilidad de tu marca en la comunidad tech más activa de la región.",
  },
  {
    Icon: Zap,
    title: "Liderazgo de opinión",
    tone: "text-brand-yellow-text",
    rule: "bg-brand-yellow",
    body: "Posiciona tu empresa como líder tecnológico compartiendo conocimiento y experiencia.",
  },
  {
    Icon: Heart,
    title: "Impacto en la comunidad",
    tone: "text-brand-green-text",
    rule: "bg-brand-green",
    body: "Contribuye al crecimiento del ecosistema tecnológico y genera impacto social positivo.",
  },
];

const metadata = {
  title: "Patrocinadores - Google Developer Group Ica",
  description:
    "Descubre las empresas que apoyan al GDG ICA y cómo tu organización puede patrocinar eventos tech en Ica, Perú. Conecta con más de 5000 desarrolladores de la región.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/sponsors/",
  schema: buildSponsorsSchema(sponsors),
};
---

<Layout {...metadata}>
  <HeroPage
    eyebrow="Patrocinadores"
    title="Quienes hacen posible la comunidad"
    description="Agradecemos a las empresas y organizaciones que hacen posible nuestra misión de democratizar el acceso al conocimiento tecnológico."
  >
    <StatsBar
      class="border-line mt-16 border-t pt-12"
      stats={[
        {
          value: `${stats.totalSponsors}+`,
          label: "Patrocinadores activos",
          color: "blue",
        },
        {
          value: stats.annualSupport,
          label: "Apoyo anual total",
          color: "red",
        },
        {
          value: `${stats.sponsoredEvents}+`,
          label: "Eventos patrocinados",
          color: "yellow",
        },
        {
          value: `${stats.developersReached}+`,
          label: "Desarrolladores alcanzados",
          color: "green",
        },
      ]}
    />
  </HeroPage>

  {
    featuredSponsors.length > 0 && (
      <section class="border-line bg-surface border-t">
        <div class="section container">
          <SectionHeader
            eyebrow="Principales"
            title="Socios estratégicos"
            description="Impulsan la innovación y el crecimiento de la comunidad."
          />
          <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {featuredSponsors.map((sponsor) => (
              <SponsorCard {...sponsor} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    otherSponsors.length > 0 && (
      <section class="section container">
        <SectionHeader
          eyebrow="Todos"
          title="Todos nuestros patrocinadores"
          description="Cada empresa que nos apoya es fundamental para nuestro éxito."
        />
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {otherSponsors.map((sponsor) => (
            <SponsorCard {...sponsor} />
          ))}
        </div>
      </section>
    )
  }

  <section class="border-line bg-surface border-t">
    <div class="section container">
      <SectionHeader
        eyebrow="Beneficios"
        title="¿Por qué patrocinar al GDG Ica?"
        description="Los beneficios tangibles de asociarse con la comunidad de desarrolladores más activa de la región."
      />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {
          benefits.map(({ Icon, title, body, tone, rule }) => (
            <FeatureCard interactive class="flex flex-col">
              <span
                class={`mb-5 block h-1 w-9 rounded-full ${rule}`}
                aria-hidden="true"
              />
              <Icon size={28} stroke-width={1.75} class={tone} aria-hidden />
              <h3 class="text-h4 text-fg mt-4">{title}</h3>
              <p class="text-fg-muted mt-2 text-sm">{body}</p>
            </FeatureCard>
          ))
        }
      </div>
    </div>
  </section>

  <CallToActionSection
    title="¿Quieres ser nuestro próximo patrocinador?"
    description="Únete a las empresas que apoyan el crecimiento del ecosistema tecnológico y ayúdanos a formar a los desarrolladores del futuro."
  >
    <Button
      href={links.forms.sponsor}
      target="_blank"
      variant="inverse"
      size="lg"
    >
      <BriefcaseBusiness size={18} stroke-width={1.75} aria-hidden />
      Quiero ser patrocinador
    </Button>
  </CallToActionSection>
</Layout>
