---
import Layout from "@/layouts/Layout.astro";
import PersonCard from "@/components/PersonCard.astro";
import CallToActionSection from "@/components/CallToActionSection.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import Button from "@/components/Button.astro";
import HeroPage from "@/components/HeroPage.astro";
import { HandshakeIcon } from "@lucide/astro";
// data
import { getCollection } from "astro:content";
import { fetchStats, fetchLinks } from "@/loaders/transform-site-config";
import StatsBar from "@/components/StatsBar.astro";
import VolunteerRoleCard from "@/components/VolunteerRoleCard.astro";

const volunteersCollection = await getCollection("volunteers");
const volunteers = volunteersCollection.map((entry) => entry.data);
const volunteerRolesCollection = await getCollection("volunteerRoles");
const roles = volunteerRolesCollection.map((entry) => entry.data);
const stats = await fetchStats();
const links = await fetchLinks();

const metadata = {
  title: "Voluntarios - Google Developer Group Ica",
  description:
    "Conoce a los 50+ voluntarios del GDG ICA y descubre oportunidades en fotografía, soporte técnico, diseño, logística y más. Únete al equipo voluntario de Ica.",
  image: "https://gdgica.com/gdg-logo.png",
  url: "https://gdgica.com/volunteers/",
};
---

<Layout {...metadata}>
  <HeroPage
    eyebrow="Voluntarios"
    title="El corazón de cada evento"
    description="Personas que dedican su tiempo y talento para hacer que cada evento sea especial. Conoce a quienes hacen posible la magia del GDG Ica."
  >
    <StatsBar
      class="border-line mt-16 border-t pt-12"
      stats={[
        {
          value: `${stats.activeVolunteers}+`,
          label: "Voluntarios activos",
          color: "blue",
        },
        {
          value: `${stats.volunteerHours}+`,
          label: "Horas contribuidas",
          color: "red",
        },
        {
          value: `${stats.eventsSupported}+`,
          label: "Eventos apoyados",
          color: "yellow",
        },
        {
          value: `${stats.volunteerAreas}`,
          label: "Áreas de apoyo",
          color: "green",
        },
      ]}
    />
  </HeroPage>

  {
    volunteers.length > 0 && (
      <section class="section container">
        <SectionHeader
          eyebrow="Equipo voluntario"
          title="Todos nuestros voluntarios"
          description="Conoce a las personas que dedican su tiempo a la comunidad."
        />
        <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {volunteers.map((volunteer) => (
            <PersonCard person={volunteer} />
          ))}
        </div>
      </section>
    )
  }

  <section class="border-line bg-surface border-t">
    <div class="section container">
      <SectionHeader
        eyebrow="Oportunidades"
        title="Formas de contribuir"
        description="Encuentra la forma perfecta de aportar a la comunidad según tus habilidades e intereses."
      />
      <div
        class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
      >
        {roles.map((role) => <VolunteerRoleCard {...role} />)}
      </div>
    </div>
  </section>

  <CallToActionSection
    title="¿Quieres ser voluntario?"
    description="Únete al equipo de voluntarios y ayúdanos a crear experiencias memorables. No importa cuánto tiempo tengas disponible, toda ayuda es valiosa."
  >
    <Button
      href={links.forms.volunteer}
      target="_blank"
      variant="inverse"
      size="lg"
    >
      <HandshakeIcon size={18} stroke-width={1.75} aria-hidden />
      Ser voluntario
    </Button>
  </CallToActionSection>
</Layout>
