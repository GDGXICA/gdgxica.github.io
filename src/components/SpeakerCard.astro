---
import SocialLinks from "./SocialLinks.astro";

interface Props {
  image?: string;
  name: string;
  role?: string;
  description?: string;
  linkedin?: string;
  web?: string;
  youtube?: string;
  twitter?: string;
  github?: string;
}

const {
  image,
  name,
  role,
  description,
  linkedin,
  web,
  youtube,
  twitter,
  github,
} = Astro.props;

// The speaker schema keeps its social URLs flat; SocialLinks takes them grouped
// and does its own `http` filtering, so five hand-rolled anchors (each with a
// hardcoded grey, no hover and no accessible name) collapse to one call.
const links = { linkedin, twitter, github, youtube, web };
---

<article class="card flex h-full flex-col gap-5 p-6 sm:flex-row">
  <img
    src={image || "/placeholder.svg"}
    width={112}
    height={112}
    alt=""
    class="bg-inset h-28 w-28 shrink-0 rounded-lg object-cover object-center"
    loading="lazy"
    decoding="async"
  />
  <div class="min-w-0">
    <h3 class="text-h4 text-fg">{name}</h3>
    {
      role && (
        <p class="text-brand-blue-text mt-1 text-sm font-medium">{role}</p>
      )
    }
    <SocialLinks links={links} name={name} size={16} class="mt-2 -ml-2" />
    {
      description && (
        <p class="text-fg-muted mt-2 text-sm text-pretty">{description}</p>
      )
    }
  </div>
</article>
