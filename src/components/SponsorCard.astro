---
import { ArrowUpRight } from "@lucide/astro";
import { cn } from "@/utils/cn";

interface Props {
  name: string;
  logo?: string;
  sector?: string;
  description?: string;
  eventsSponsored?: number;
  sinceYear?: number | string;
  website?: string;
  featured?: boolean;
  class?: string;
}

const {
  name,
  logo,
  sector,
  description,
  eventsSponsored,
  sinceYear,
  website,
  featured = false,
  class: className,
} = Astro.props;
---

<article
  class={cn(
    "card card-interactive group relative flex h-full flex-col p-6",
    className
  )}
>
  {/* Fixed-height plate so logos of wildly different aspect ratios line up. */}
  <div
    class="bg-inset flex h-20 w-full items-center justify-center rounded-md px-4"
  >
    <img
      src={logo || "/placeholder.svg"}
      alt={`Logo de ${name}`}
      class={cn(
        "max-h-12 w-auto object-contain",
        featured ? "max-h-14" : "max-h-12"
      )}
      width={160}
      height={56}
      loading="lazy"
      decoding="async"
    />
  </div>

  <h3 class="text-h4 text-fg mt-5">
    {
      website ? (
        <a
          href={website}
          target="_blank"
          rel="noopener noreferrer"
          class="after:absolute after:inset-0 after:content-['']"
        >
          {name}
        </a>
      ) : (
        name
      )
    }
  </h3>

  {
    sector && (
      <p class="text-fg-subtle mt-1 text-xs font-semibold tracking-wide uppercase">
        {sector}
      </p>
    )
  }

  {
    description && (
      <p class="text-fg-muted mt-3 line-clamp-4 text-sm">{description}</p>
    )
  }

  <dl class="border-line mt-auto flex items-center gap-6 border-t pt-5 text-sm">
    {
      eventsSponsored !== undefined && (
        <div>
          <dt class="text-fg-subtle text-xs">Eventos</dt>
          <dd class="text-fg font-semibold tabular-nums">{eventsSponsored}</dd>
        </div>
      )
    }
    {
      sinceYear !== undefined && (
        <div>
          <dt class="text-fg-subtle text-xs">Desde</dt>
          <dd class="text-fg font-semibold tabular-nums">{sinceYear}</dd>
        </div>
      )
    }
    {
      website && (
        <p class="text-accent ml-auto flex items-center gap-1 text-sm font-semibold">
          Visitar
          <ArrowUpRight
            size={15}
            stroke-width={2}
            class="transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
            aria-hidden
          />
        </p>
      )
    }
  </dl>
</article>
