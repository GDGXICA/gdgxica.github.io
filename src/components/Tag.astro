---
import { Star } from "@lucide/astro";
import { cn } from "@/utils/cn";

const typeStyles = {
  devfest: "bg-brand-blue-soft text-brand-blue-text",
  io: "bg-brand-red-soft text-brand-red-text",
  studyjam: "bg-brand-green-soft text-brand-green-text",
  wtm: "bg-accent-violet-soft text-accent-violet",
  meetup: "bg-brand-yellow-soft text-brand-yellow-text",
  hackaton: "bg-accent-orange-soft text-accent-orange",
  upcoming: "bg-brand-green-soft text-brand-green-text",
  "in-progress": "bg-brand-blue-soft text-brand-blue-text",
  completed: "bg-inset text-fg-muted",
} as const;

type Type = keyof typeof typeStyles;

interface Props {
  label: string;
  type?: Type;
  isHighlight?: boolean;
  class?: string;
}

const { label, type, isHighlight, class: className } = Astro.props;
---

{
  isHighlight ? (
    <span
      class={cn(
        "bg-brand-yellow-soft text-brand-yellow-text inline-flex items-center justify-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold",
        className
      )}
    >
      <Star size={13} aria-hidden />
      {label}
    </span>
  ) : (
    <span
      class={cn(
        "inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold",
        typeStyles[type as Type] ?? typeStyles.completed,
        className
      )}
    >
      {label}
    </span>
  )
}
