---
import { Calendar } from "@lucide/astro";
import Tag from "./Tag.astro";
import SocialLinks from "./SocialLinks.astro";
import { cn } from "@/utils/cn";

interface Person {
  name: string;
  avatar?: string;
  role?: string;
  bio?: string;
  tags?: string[];
  joinedDate?: string;
  responsibilities?: string[];
  links?: {
    linkedin?: string;
    twitter?: string;
    github?: string;
    web?: string;
  };
}

interface Props {
  person: Person;
  /** `detailed` adds join date and responsibilities when the data has them. */
  variant?: "default" | "detailed";
  class?: string;
}

const { person, variant = "default", class: className } = Astro.props;

const tags = person.tags?.filter(Boolean) ?? [];
const responsibilities = person.responsibilities?.filter(Boolean) ?? [];
const showJoined = variant === "detailed" && Boolean(person.joinedDate?.trim());
const showResponsibilities =
  variant === "detailed" && responsibilities.length > 0;
---

<article
  class={cn("card card-interactive flex h-full flex-col p-6", className)}
>
  <div class="flex items-center gap-4">
    <img
      src={person.avatar || "/placeholder.svg"}
      alt=""
      width={72}
      height={72}
      loading="lazy"
      decoding="async"
      class="bg-inset h-18 w-18 shrink-0 rounded-full object-cover"
    />
    <div class="min-w-0">
      {/* Never truncate a person's name — wrap instead. */}
      <h3 class="text-h4 text-fg text-balance">{person.name}</h3>
      {
        person.role && (
          <p class="text-brand-blue-text mt-1 text-sm font-medium">
            {person.role}
          </p>
        )
      }
    </div>
  </div>

  {
    person.bio && (
      <p class="text-fg-muted mt-4 line-clamp-3 text-sm">{person.bio}</p>
    )
  }

  {
    showJoined && (
      <p class="text-fg-subtle mt-4 flex items-center gap-2 text-sm">
        <Calendar size={15} stroke-width={1.75} aria-hidden />
        Desde {person.joinedDate}
      </p>
    )
  }

  {
    showResponsibilities && (
      <div class="mt-4">
        <h4 class="text-fg mb-2 text-sm font-semibold">Responsabilidades</h4>
        <ul class="text-fg-muted list-disc space-y-1 pl-5 text-sm">
          {responsibilities.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    )
  }

  {
    tags.length > 0 && (
      <ul class="mt-4 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <li>
            <Tag label={tag} />
          </li>
        ))}
      </ul>
    )
  }

  <div class="border-line mt-auto flex items-center pt-4">
    <SocialLinks links={person.links} name={person.name} class="-ml-2" />
  </div>
</article>
