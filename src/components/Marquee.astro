---
// Purely decorative community photos. The whole block is aria-hidden, which is
// more honest than shipping empty-alt images into the accessibility tree.
// Horizontal strip: this now runs as a full-width band, where the previous
// two-column vertical scroll turned into two enormous columns.
const rows = [
  [
    "/carousel/01.webp",
    "/carousel/02.webp",
    "/carousel/03.webp",
    "/carousel/04.webp",
    "/carousel/05.webp",
    "/carousel/06.webp",
    "/carousel/07.webp",
    "/carousel/08.webp",
  ],
  [
    "/carousel/09.webp",
    "/carousel/10.webp",
    "/carousel/11.webp",
    "/carousel/12.webp",
    "/carousel/13.webp",
    "/carousel/14.webp",
    "/carousel/15.webp",
    "/carousel/16.webp",
  ],
];
---

<div class="marquee-root" aria-hidden="true">
  {
    rows.map((images, index) => (
      <div class:list={["marquee", index % 2 === 1 && "marquee--reverse"]}>
        {/* Two identical groups back to back — the loop is only seamless if
            both render the same sequence in the same order. */}
        {[0, 1].map(() => (
          <div class="marquee__group">
            {images.map((url) => (
              <img
                src={url}
                alt=""
                width={480}
                height={360}
                loading="lazy"
                decoding="async"
              />
            ))}
          </div>
        ))}
      </div>
    ))
  }
</div>

<style>
  .marquee-root {
    --gap: 0.75rem;
    --duration: 70s;
    display: flex;
    flex-direction: column;
    gap: var(--gap);
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 8%,
      black 92%,
      transparent
    );
  }

  .marquee {
    display: flex;
    flex-direction: row;
    gap: var(--gap);
    overflow: hidden;
    user-select: none;
  }

  .marquee__group {
    display: flex;
    flex-direction: row;
    flex-shrink: 0;
    gap: var(--gap);
    animation: marquee-scroll var(--duration) linear infinite;
  }

  .marquee--reverse .marquee__group {
    animation-direction: reverse;
  }

  .marquee img {
    height: clamp(8rem, 16vw, 13rem);
    width: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-md);
    background-color: var(--inset);
    filter: saturate(0.92) contrast(1.06) brightness(0.99) sepia(0.06);
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      /* One full group plus the gap that follows it. */
      transform: translateX(calc(-100% - var(--gap)));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__group {
      animation: none;
    }
  }
</style>
