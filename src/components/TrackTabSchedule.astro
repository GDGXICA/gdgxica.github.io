---
import { MapPin } from "@lucide/astro";
import ScheduleCard from "./ScheduleCard.astro";
import { cn } from "@/utils/cn";

interface Track {
  id: string;
  name: string;
  color: string;
  description: string;
}

interface Session {
  id: number;
  title: string;
  name: string;
  image: string;
  role: string;
  type: string;
  startTime: string;
  endTime: string;
  duration: string;
  isKeynote?: boolean;
}

interface Schedule {
  trackSessions: Record<string, Session[]>;
}

interface Props {
  schedule: Schedule;
  tracks: Track[];
}

const { schedule, tracks } = Astro.props;
const trackSessions = schedule.trackSessions;

// The data's `track.color` is a raw per-event hex (a mid orange, a mid blue, …).
// Piping it into `style` produced text that failed contrast in light mode and
// again in dark mode, and it could never respond to the theme. Tracks instead
// take the next slot in the brand palette, so every track is theme-aware and
// its text tier is the contrast-safe one. `track.color` stays in the data,
// untouched — it is simply no longer used for rendering.
const TONES = [
  { dot: "bg-brand-blue", text: "text-brand-blue-text" },
  { dot: "bg-brand-red", text: "text-brand-red-text" },
  { dot: "bg-brand-yellow", text: "text-brand-yellow-text" },
  { dot: "bg-brand-green", text: "text-brand-green-text" },
] as const;

const visibleTracks = tracks.filter(
  (track) => (trackSessions[track.id]?.length ?? 0) > 0
);
---

{
  visibleTracks.length > 0 && (
    <div data-track-tabs>
      <div class="border-line -mx-1 overflow-x-auto border-b px-1">
        <div
          role="tablist"
          aria-label="Salas del evento"
          class="flex min-w-max gap-1"
        >
          {visibleTracks.map((track, index) => {
            const tone = TONES[index % TONES.length];
            return (
              <button
                type="button"
                role="tab"
                id={`track-tab-${track.id}`}
                aria-controls={`track-panel-${track.id}`}
                aria-selected={index === 0 ? "true" : "false"}
                tabindex={index === 0 ? 0 : -1}
                data-track={track.id}
                class="text-fg-muted hover:text-fg hover:bg-inset aria-selected:text-fg aria-selected:border-accent -mb-px flex items-center gap-2.5 rounded-t-md border-b-2 border-transparent px-4 py-3 text-sm font-semibold whitespace-nowrap transition-colors duration-200"
              >
                <span
                  class={cn("h-2 w-2 shrink-0 rounded-full", tone.dot)}
                  aria-hidden="true"
                />
                {track.name}
              </button>
            );
          })}
        </div>
      </div>

      {visibleTracks.map((track, index) => {
        const tone = TONES[index % TONES.length];
        return (
          <div
            id={`track-panel-${track.id}`}
            role="tabpanel"
            aria-labelledby={`track-tab-${track.id}`}
            tabindex={0}
            hidden={index !== 0}
            data-track-panel
            class="mt-8"
          >
            <div class="bg-surface border-line rounded-lg border p-5">
              <h3 class="text-h3 text-fg flex items-center gap-2.5">
                <MapPin
                  size={20}
                  stroke-width={1.75}
                  class={tone.text}
                  aria-hidden
                />
                {track.name}
              </h3>
              {track.description && (
                <p class="text-fg-muted mt-2 text-sm text-pretty">
                  {track.description}
                </p>
              )}
            </div>

            <div class="mt-6 flex flex-col gap-4">
              {trackSessions[track.id].map((session) => (
                <ScheduleCard {...session} as="h4" />
              ))}
            </div>
          </div>
        );
      })}
    </div>
  )
}

<script is:inline>
  (function () {
    function activate(tablist, tab) {
      const tabs = Array.prototype.slice.call(
        tablist.querySelectorAll('[role="tab"]')
      );
      const root = tablist.closest("[data-track-tabs]");
      if (!root) return;

      tabs.forEach(function (item) {
        const selected = item === tab;
        item.setAttribute("aria-selected", selected ? "true" : "false");
        item.tabIndex = selected ? 0 : -1;
      });

      root.querySelectorAll("[data-track-panel]").forEach(function (panel) {
        panel.hidden = panel.id !== "track-panel-" + tab.dataset.track;
      });
    }

    function init() {
      document
        .querySelectorAll("[data-track-tabs] [role='tablist']")
        .forEach(function (tablist) {
          if (tablist.dataset.bound === "true") return;
          tablist.dataset.bound = "true";

          const tabs = Array.prototype.slice.call(
            tablist.querySelectorAll('[role="tab"]')
          );

          tablist.addEventListener("click", function (event) {
            const tab = event.target.closest('[role="tab"]');
            if (tab) activate(tablist, tab);
          });

          tablist.addEventListener("keydown", function (event) {
            const current = tabs.indexOf(document.activeElement);
            if (current === -1) return;

            let next = null;
            if (event.key === "ArrowRight")
              next = tabs[(current + 1) % tabs.length];
            else if (event.key === "ArrowLeft")
              next = tabs[(current - 1 + tabs.length) % tabs.length];
            else if (event.key === "Home") next = tabs[0];
            else if (event.key === "End") next = tabs[tabs.length - 1];
            if (!next) return;

            event.preventDefault();
            activate(tablist, next);
            next.focus();
          });
        });
    }

    init();
    document.addEventListener("astro:after-swap", init);
  })();
</script>
