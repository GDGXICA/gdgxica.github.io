---
import {
  Calendar,
  Clock,
  MapPin,
  Globe,
  Users,
  ArrowRight,
} from "@lucide/astro";
import Tag from "./Tag.astro";
import { cn } from "@/utils/cn";

interface Props {
  isHorizontal?: boolean;
  name: string;
  image?: string;
  shortDescription?: string;
  date?: string;
  time?: string;
  location?: { name?: string };
  isVirtual?: boolean;
  participants?: number;
  maxParticipants?: number;
  category?: { label: string; type: string };
  status?: { label: string; type: string };
  isHighlight?: boolean;
  tags?: string[];
  slug: string;
  class?: string;
}

const {
  isHorizontal = false,
  name,
  image,
  shortDescription,
  date,
  time,
  location,
  isVirtual,
  participants,
  maxParticipants,
  category,
  status,
  isHighlight,
  tags = [],
  slug,
  class: className,
} = Astro.props;

const href = `/events/${slug}`;

// Previously this list was duplicated verbatim between the two layouts, and the
// horizontal variant hardcoded `category`/`status` so every featured event
// rendered as "DevFest · Próximo" regardless of its real values.
const meta = [
  { Icon: Calendar, text: date, tone: "text-brand-blue-text" },
  { Icon: Clock, text: time, tone: "text-brand-red-text" },
  isVirtual
    ? { Icon: Globe, text: "Evento virtual", tone: "text-brand-green-text" }
    : { Icon: MapPin, text: location?.name, tone: "text-brand-green-text" },
  maxParticipants
    ? {
        Icon: Users,
        text: `${participants ?? 0}/${maxParticipants} registrados`,
        tone: "text-brand-yellow-text",
      }
    : null,
].filter((item): item is NonNullable<typeof item> => Boolean(item?.text));

const visibleTags = tags.filter(Boolean).slice(0, 5);
const remainingTags = tags.filter(Boolean).length - visibleTags.length;
---

<article
  class={cn(
    "card card-interactive group relative flex h-full flex-col overflow-hidden",
    isHorizontal && "md:flex-row",
    className
  )}
>
  <div
    class={cn(
      "bg-inset relative shrink-0 overflow-hidden",
      isHorizontal ? "md:w-2/5" : ""
    )}
  >
    <img
      src={image || "/placeholder.svg"}
      alt=""
      width={640}
      height={360}
      loading="lazy"
      decoding="async"
      class={cn(
        "w-full object-cover transition-transform duration-500 ease-[var(--ease-out-quint)] group-hover:scale-[1.03]",
        isHorizontal ? "h-56 md:h-full md:min-h-[18rem]" : "aspect-video"
      )}
    />
    <div class="absolute top-4 left-4 flex flex-wrap gap-2">
      {category && <Tag label={category.label} type={category.type as never} />}
      {status && <Tag label={status.label} type={status.type as never} />}
    </div>
    {
      isHighlight && (
        <div class="absolute top-4 right-4">
          <Tag label="Destacado" isHighlight />
        </div>
      )
    }
  </div>

  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-h3 text-fg">
      <a
        href={href}
        class="after:absolute after:inset-0 after:content-['']"
        aria-label={`Ver detalles de ${name}`}
      >
        {name}
      </a>
    </h3>

    {
      shortDescription && (
        <p class="text-fg-muted mt-2 line-clamp-2 text-sm">
          {shortDescription}
        </p>
      )
    }

    <ul class="mt-5 flex flex-col gap-2.5">
      {
        meta.map(({ Icon, text, tone }) => (
          <li class="text-fg-muted flex items-center gap-2.5 text-sm">
            <Icon size={16} stroke-width={1.75} class={tone} aria-hidden />
            <span class="min-w-0 truncate">{text}</span>
          </li>
        ))
      }
    </ul>

    {
      visibleTags.length > 0 && (
        <ul class="mt-5 flex flex-wrap gap-1.5">
          {visibleTags.map((tag) => (
            <li>
              <Tag label={tag} />
            </li>
          ))}
          {remainingTags > 0 && (
            <li>
              <Tag label={`+${remainingTags}`} />
            </li>
          )}
        </ul>
      )
    }

    <p
      class="text-accent mt-auto flex items-center gap-1.5 pt-6 text-sm font-semibold"
    >
      Ver detalles
      <ArrowRight
        size={16}
        stroke-width={2}
        class="transition-transform duration-200 group-hover:translate-x-1"
        aria-hidden
      />
    </p>
  </div>
</article>
