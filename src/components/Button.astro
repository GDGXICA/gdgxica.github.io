---
import { cn } from "@/utils/cn";

interface Props {
  href?: string;
  target?: string;
  variant?: "primary" | "secondary" | "ghost" | "inverse" | "inverse-outline";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const {
  href,
  target,
  variant = "primary",
  size = "md",
  type,
  class: className,
  ...rest
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md border font-semibold " +
  "transition-[background-color,border-color,color,box-shadow,transform] duration-200 ease-[var(--ease-out-quint)] " +
  "active:translate-y-px disabled:pointer-events-none disabled:opacity-50";

const variants = {
  primary:
    "border-accent bg-accent text-accent-fg shadow-[var(--shadow-card)] " +
    "hover:border-accent-hover hover:bg-accent-hover hover:shadow-[var(--shadow-card-hover)] " +
    "active:border-accent-active active:bg-accent-active",
  secondary:
    "border-line-strong bg-raised text-fg " +
    "hover:border-fg-subtle hover:bg-inset active:bg-line",
  ghost:
    "border-transparent bg-transparent text-fg-muted " +
    "hover:bg-inset hover:text-fg active:bg-line",
  inverse:
    "border-transparent bg-white text-ink shadow-[var(--shadow-card)] " +
    "hover:bg-white/90 hover:shadow-[var(--shadow-card-hover)] active:bg-white/80",
  // Secondary action on the ink surface — a bare ghost button reads as plain
  // text there, so this keeps a visible edge.
  "inverse-outline":
    "border-white/25 bg-transparent text-fg-on-ink " +
    "hover:border-white/40 hover:bg-white/10 active:bg-white/15",
} as const;

const sizes = {
  sm: "px-4 py-2 text-sm",
  md: "px-6 py-2.5 text-ui",
  lg: "px-7 py-3.5 text-base",
} as const;

const classes = cn(base, variants[variant], sizes[size], className);

// Anything that navigates is an <a>; anything else is a real <button>.
const isLink = Boolean(href);
const relValue =
  target === "_blank"
    ? "noopener noreferrer"
    : (rest.rel as string | undefined);
---

{
  isLink ? (
    <a href={href} target={target} rel={relValue} class={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type ?? "button"} class={classes} {...rest}>
      <slot />
    </button>
  )
}
