---
import { cn } from "@/utils/cn";

interface Props {
  class?: string;
  className?: string;
  interactive?: boolean;
}

// `className` is accepted for backwards compatibility with existing call sites.
const { class: classProp, className, interactive = false } = Astro.props;
---

<article
  class={cn(
    "card p-6",
    interactive && "card-interactive",
    classProp,
    className
  )}
>
  <slot />
</article>
