---
import { fetchLinks } from "@/loaders/transform-site-config";

const siteLinks = await fetchLinks();
const year = new Date().getFullYear();

const columns = [
  {
    title: "Comunidad",
    links: [
      { text: "Nosotros", url: "/about" },
      { text: "Equipo", url: "/team" },
      { text: "Voluntarios", url: "/volunteers" },
    ],
  },
  {
    title: "Eventos",
    links: [
      { text: "Todos los eventos", url: "/events" },
      { text: "Patrocinadores", url: "/sponsors" },
      { text: "RSS", url: "/rss.xml" },
    ],
  },
  {
    title: "Conectar",
    links: [
      { text: "LinkedIn", url: siteLinks.social.linkedin, external: true },
      { text: "Facebook", url: siteLinks.social.facebook, external: true },
      { text: "Instagram", url: siteLinks.social.instagram, external: true },
    ],
  },
];

const linkClass =
  "text-fg-on-ink-muted hover:text-fg-on-ink rounded-xs text-sm transition-colors duration-200";
---

<footer class="bg-ink relative">
  <div class="brand-rule absolute inset-x-0 top-0 h-1" aria-hidden="true"></div>

  <div class="container py-16">
    <div class="grid gap-12 md:grid-cols-[1.5fr_repeat(3,1fr)]">
      <div class="max-w-xs">
        <div class="flex items-center gap-3">
          <img
            src="/gdg-logo.png"
            alt=""
            height={36}
            width={36}
            class="h-9 w-9"
          />
          <p class="text-fg-on-ink text-base font-bold tracking-tight">
            GDG ICA
          </p>
        </div>
        <p class="text-fg-on-ink-muted mt-4 text-sm">
          Construir una comunidad de desarrolladores más fuerte a través de la
          colaboración y el aprendizaje.
        </p>
      </div>

      {
        columns.map((column) => (
          <nav aria-label={column.title}>
            <h2 class="text-fg-on-ink text-sm font-semibold">{column.title}</h2>
            <ul class="mt-4 flex flex-col gap-3">
              {column.links.map((link) => (
                <li>
                  <a
                    class={linkClass}
                    href={link.url}
                    target={link.external ? "_blank" : undefined}
                    rel={link.external ? "noopener noreferrer" : undefined}
                  >
                    {link.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div
      class="mt-14 flex flex-col items-center justify-between gap-6 border-t border-white/10 pt-8 md:flex-row"
    >
      <p class="text-fg-on-ink-muted text-center text-sm">
        © {year} Google Developer Groups ICA. Todos los derechos reservados.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        <a
          href="https://github.com/GDGXICA/gdgxica.github.io"
          target="_blank"
          rel="noopener noreferrer"
          class={`${linkClass} inline-flex items-center gap-2`}
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            class="h-4 w-4"
          >
            <path
              d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.11.79-.25.79-.56v-2c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.68-1.28-1.68-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.59.23 2.76.11 3.05.73.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.41-5.27 5.69.41.36.77 1.06.77 2.14v3.17c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"
            ></path>
          </svg>
          Contribuye en GitHub
        </a>
        <a href="/terms-and-conditions" class={linkClass}>
          Términos y Condiciones
        </a>
        <a href="/privacy-policy" class={linkClass}>Política de Privacidad</a>
      </div>
    </div>
  </div>
</footer>
